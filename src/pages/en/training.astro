---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Video, { type VideoFilm } from "~/components/Video.astro";
import { readFileSync } from "node:fs";
import { resolve } from "node:path";

const root = resolve(import.meta.dirname, "../../../public/videos");

function loadTranscript(name: string): string {
  return readFileSync(resolve(root, `${name}.txt`), "utf8")
    .split("\n")
    .map((l) => l.replace(/^ /, "").trim())
    .filter(Boolean)
    .join("\n");
}

const films: VideoFilm[] = [
  {
    id: "opplaeringsfilm",
    title: "Training film — anaphylaxis in a clinical situation",
    duration: "PT5M10S",
    durationLabel: "5:10",
    uploadDate: "2026-04-29",
    inLanguage: "nb-NO",
    description:
      "Step-by-step management of an anaphylactic reaction on a ward: an intensive-care nurse alerts the doctor, fetches the anaphylaxis kit and administers adrenaline by protocol. The film is in Norwegian.",
    poster: "/videos/opplaeringsfilm-poster.jpg",
    sources: [{ src: "/videos/opplaeringsfilm.mp4", type: "video/mp4" }],
    subtitles: { src: "/videos/opplaeringsfilm.vtt", srclang: "no", label: "Norsk" },
    hasBurnedInSubtitles: false,
    transcript: loadTranscript("opplaeringsfilm"),
  },
  {
    id: "demo",
    title: "The kit — contents, layout and use",
    duration: "PT3M35S",
    durationLabel: "3:35",
    uploadDate: "2026-04-29",
    inLanguage: "nb-NO",
    description:
      "A walkthrough of the anaphylaxis kit's physical layout, contents (medication and equipment), flowchart, QR code and cleaning instructions. The film is in Norwegian.",
    poster: "/videos/demo-poster.jpg",
    sources: [{ src: "/videos/demo.mp4", type: "video/mp4" }],
    subtitles: { src: "/videos/demo.vtt", srclang: "no", label: "Norsk" },
    hasBurnedInSubtitles: true,
    transcript: loadTranscript("demo"),
  },
];
---

<BaseLayout
  locale="en"
  altUrl="/opplaering"
  title="Training videos — EmendaKit"
  description="Two training films on managing anaphylaxis and using the EmendaKit anaphylaxis kit."
>
  <section class="intro">
    <div class="container">
      <div class="eyebrow">Training · Anaphylaxis</div>
      <h1>Training videos</h1>
      <p class="lede">
        Two short films for clinicians: managing an anaphylactic reaction, and a
        walkthrough of the kit's contents and use. The QR code on the kit points
        here. The films are in Norwegian.
      </p>
    </div>
  </section>

  {films.map((film) => (
    <section class="film-shell">
      <div class="container">
        <Video
          film={film}
          indexLabel={`№ ${film.id === "opplaeringsfilm" ? "01" : "02"}`}
          showTranscript={false}
        />
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .container { max-width: 1080px; margin: 0 auto; padding: 0 32px; }
  .intro { padding: 80px 0 32px; }
  .intro .eyebrow {
    font-family: var(--font-mono);
    font-size: 12px; color: var(--color-navy);
    text-transform: uppercase; letter-spacing: 0.1em;
    margin-bottom: 18px;
  }
  .intro h1 {
    font-family: var(--font-display);
    font-size: clamp(40px, 5.5vw, 64px); font-weight: 500;
    letter-spacing: -0.03em; line-height: 0.98;
    margin: 0 0 22px;
  }
  .intro .lede {
    font-size: 18px; line-height: 1.55;
    color: var(--color-ink-2);
    max-width: 620px;
    margin: 0;
  }

  .film-shell { padding: 0; }
</style>
