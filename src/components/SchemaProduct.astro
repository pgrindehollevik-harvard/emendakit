---
import { SITE } from "~/lib/site";

interface Props {
  name: string;
  description: string;
  url: string;
  image?: string;
  productNumber: number;
  audience?: string;
  deliveryTime?: string;
}

const { name, description, url, image, productNumber, audience, deliveryTime } = Astro.props;

const data = {
  "@context": "https://schema.org",
  "@type": "Product",
  name,
  description,
  image: image ? new URL(image, SITE.url).href : undefined,
  url: new URL(url, SITE.url).href,
  brand: {
    "@type": "Brand",
    name: SITE.name,
  },
  manufacturer: {
    "@type": "Organization",
    name: SITE.legalName,
    url: SITE.url,
  },
  category: "Medical emergency equipment / Anaphylaxis kit",
  countryOfOrigin: "Norway",
  audience: audience
    ? { "@type": "PeopleAudience", audienceType: audience }
    : undefined,
  sku: `EMENDAKIT-${productNumber.toString().padStart(2, "0")}`,
  offers: {
    "@type": "Offer",
    url: new URL(url, SITE.url).href,
    availability: "https://schema.org/LimitedAvailability",
    priceCurrency: "NOK",
    price: undefined,
    priceSpecification: {
      "@type": "PriceSpecification",
      priceCurrency: "NOK",
      valueAddedTaxIncluded: false,
    },
    seller: {
      "@type": "Organization",
      name: SITE.legalName,
      email: SITE.email,
    },
    eligibleRegion: { "@type": "Country", name: "Norway" },
    shippingDetails: {
      "@type": "OfferShippingDetails",
      shippingDestination: { "@type": "DefinedRegion", addressCountry: "NO" },
      deliveryTime: {
        "@type": "ShippingDeliveryTime",
        name: deliveryTime ?? "Ca. 2 uker",
        handlingTime: {
          "@type": "QuantitativeValue",
          minValue: 14,
          maxValue: 14,
          unitCode: "DAY",
        },
      },
    },
  },
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(data)} />
