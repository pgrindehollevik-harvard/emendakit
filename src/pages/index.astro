---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProductCard from "~/components/ProductCard.astro";
import FounderCard from "~/components/FounderCard.astro";
import SectionField from "~/components/SectionField.astro";
import CTAStrip from "~/components/CTAStrip.astro";

import heroPhoto from "~/assets/photos/hero-helicopter-hangar.jpg";
import productHospitalPhoto from "~/assets/photos/product-hospital-studio.webp";
import productDentistPhoto from "~/assets/photos/product-dentist-contents.jpg";
import fieldAmbulancePhoto from "~/assets/photos/field-ambulance-interior.jpg";
import kjerstiPhoto from "~/assets/photos/founder-kjersti-portrait.jpg";
import gregersPhoto from "~/assets/photos/founder-gregers-portrait.jpg";

const products = (await getCollection("products", ({ data }) => data.locale === "no"))
  .sort((a, b) => a.data.productNumber - b.data.productNumber);
---

<BaseLayout
  locale="no"
  altUrl="/en/"
  title="EmendaKit — Anafylaksiskrin designet og bygget i Norge av helsepersonell"
  description="EmendaKit utvikler anafylaksiskrin for sykehus, ambulanse, fødestue og tannlegeklinikk. Designet av en anestesilege og en jordmor. Pakket etter nasjonalt flytskjema."
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="hero-tag">
          <span class="pulse"></span>
          Designet og bygget i Norge av helsepersonell
        </span>
        <h1 class="display">
          Et akuttskrin designet <span>for når hvert sekund teller.</span>
        </h1>
        <p class="lede">
          Anafylaksiskrin utviklet av en anestesilege og en jordmor, for klinikere som
          ikke har tid til å lete. Vanntett. Støtsikkert. Pakket etter norsk anafylaksiprotokoll.
        </p>
      </div>
      <figure class="hero-photo">
        <Image
          src={heroPhoto}
          alt="Gregers Halvorsen i flygedrakt foran luftambulansen, med EmendaKit anafylaksiskrin"
          widths={[720, 1080, 1440, 1920]}
          sizes="(min-width: 1024px) 50vw, 100vw"
          loading="eager"
          fetchpriority="high"
        />
        <figcaption>
          <span class="stamp">FOTO 01 · Helikopterhangar · Helse Førde</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="products">
    <div class="container">
      <div class="products-head">
        <div>
          <div class="eyebrow">To skrin · ett rammeverk</div>
          <h2>Pakket for øyeblikkelig hjelp.</h2>
        </div>
        <p>
          Samme kliniske rammeverk, til to ulike bruk. Begge er pakket etter nasjonal
          anafylaksiprotokoll og levert med QR-kode til opplæringsfilmer.
        </p>
      </div>
      <div class="product-grid">
        {products.map((p) => (
          <ProductCard
            title={p.data.title}
            summary={p.data.summary}
            href={`/produkt/${p.data.urlSlug}`}
            productNumber={p.data.productNumber}
            audience={p.data.audience}
            specs={p.data.specs.slice(0, 4)}
            image={p.data.productNumber === 1 ? productHospitalPhoto : productDentistPhoto}
            imageAlt={`${p.data.title} — ${p.data.descriptor}`}
            priceLabel={p.data.priceLabel}
            orderHref={`mailto:kjersti@emendakit.com?subject=${encodeURIComponent("Inquiry - " + p.data.title)}`}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="field">
    <div class="container">
      <SectionField
        image={fieldAmbulancePhoto}
        imageAlt="Inne i luftambulansen — pasientbehandling med anafylaksiskrinet tilgjengelig"
        imageStamp="FOTO 04 · ambulanse interiør · pasientbehandling"
        eyebrow="Felt-erfaring · Helse Førde"
        title="Designet ved en pasients side, ikke ved et skrivebord."
        body="EmendaKit ble til på en avdeling, ikke i et møterom. Hver detalj, fra adrenalindekselet til QR-feltet på siden, kommer av at noen sto med en pasient og ønsket at noe var litt annerledes."
        quote="«Innovasjon gjennom kunnskap og erfaring.»"
        attribution="EmendaKits utgangspunkt, fra dag én."
      />
    </div>
  </section>

  <section class="founders">
    <div class="container">
      <div class="founders-head">
        <div class="eyebrow">Bygd av klinikere</div>
        <h2>To stemmer fra praksis, ett akuttskrin med én logikk.</h2>
      </div>
      <div class="founders-grid">
        <FounderCard
          image={kjerstiPhoto}
          imageAlt="Kjersti Grinde — jordmor og medstifter av EmendaKit"
          imageStamp="FOTO 05 · portrett · Kjersti Grinde"
          role="Medstifter · Jordmor"
          name="Kjersti Grinde"
          bio="Jordmor med fagutvikling og medisinsk simulering som spesialfelt. Designet EmendaKit for de avdelingene hun selv har jobbet i."
        />
        <FounderCard
          image={gregersPhoto}
          imageAlt="Gregers Halvorsen — anestesilege og medstifter av EmendaKit"
          imageStamp="FOTO 06 · portrett · Gregers Halvorsen"
          role="Medstifter · Anestesilege"
          name="Gregers Halvorsen"
          bio="Anestesilege ved Helse Førde, med erfaring fra luftambulanse og medisinsk simulering."
          accent="cool"
        />
      </div>
    </div>
  </section>

  <CTAStrip
    title="Trenger dere et skrin tilpasset deres avdeling?"
    body="Vi co-designer behovstilpassede medisinske skrin for fødeavdelinger, vaksinestasjoner, ambulansetjenester og avdelinger med spesielle behov."
    primary={{ href: "mailto:kjersti@emendakit.com?subject=Be%20om%20designsamtale", label: "Be om designsamtale →" }}
    secondary={{ href: "mailto:kjersti@emendakit.com", label: "kjersti@emendakit.com" }}
  />
</BaseLayout>

<style>
  .container { max-width: 1320px; margin: 0 auto; padding: 0 32px; }

  /* ─── hero ─── */
  .hero { padding: 80px 0 64px; }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.25fr);
    gap: 56px;
    align-items: center;
  }
  @media (max-width: 960px) {
    .hero-grid { grid-template-columns: 1fr; gap: 32px; }
  }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--color-cyan-soft);
    color: var(--color-navy-deep);
    font-size: 13px; font-weight: 500;
    padding: 6px 14px 6px 8px;
    border-radius: var(--radius-pill);
    margin-bottom: 28px;
  }
  .hero-tag .pulse {
    width: 8px; height: 8px;
    background: var(--color-navy);
    border-radius: var(--radius-pill);
  }
  h1.display {
    font-family: var(--font-display);
    font-size: clamp(44px, 6vw, 76px);
    line-height: 0.98;
    letter-spacing: -0.035em;
    font-weight: 500;
    margin: 0 0 24px;
    max-width: 14ch;
  }
  h1.display span { color: var(--color-ink-3); }
  .lede {
    font-size: 19px; line-height: 1.55;
    color: var(--color-ink-2);
    max-width: 540px;
  }
  .hero-photo {
    margin: 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-ink);
    position: relative;
  }
  .hero-photo img {
    width: 100%; height: auto; display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
  .hero-photo figcaption {
    position: absolute;
    inset: auto 0 0 0;
    padding: 14px 18px;
    background: linear-gradient(180deg, transparent 0%, rgb(8 12 20 / 0.7) 100%);
  }
  .stamp {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.78);
  }

  /* ─── products ─── */
  .products {
    padding: 96px 0;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-cyan-soft) 100%);
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
  }
  .products-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
    align-items: end;
  }
  .products-head .eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-navy);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
  }
  .products-head h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 3.6vw, 44px);
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 0;
    max-width: 16ch;
  }
  .products-head p {
    font-size: 17px;
    line-height: 1.6;
    color: var(--color-ink-2);
    margin: 0;
    max-width: 50ch;
  }
  .product-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  @media (max-width: 800px) {
    .products-head,
    .product-grid { grid-template-columns: 1fr; }
    .products-head { gap: 20px; }
  }

  /* ─── field ─── */
  .field { padding: 96px 0; }

  /* ─── founders ─── */
  .founders {
    padding: 96px 0;
    background: var(--color-cyan-soft);
    border-top: 1px solid var(--color-rule);
  }
  .founders-head { text-align: center; margin-bottom: 48px; }
  .founders-head .eyebrow {
    font-family: var(--font-mono); font-size: 12px; color: var(--color-navy);
    text-transform: uppercase; letter-spacing: 0.12em;
    margin-bottom: 14px;
  }
  .founders-head h2 {
    font-family: var(--font-display); font-size: clamp(32px, 3.6vw, 44px); font-weight: 500;
    letter-spacing: -0.025em; line-height: 1.05;
    margin: 0 auto;
    max-width: 22ch;
  }
  .founders-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  @media (max-width: 800px) { .founders-grid { grid-template-columns: 1fr; } }
</style>
