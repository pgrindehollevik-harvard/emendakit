---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProductCard from "~/components/ProductCard.astro";
import FounderCard from "~/components/FounderCard.astro";
import SectionField from "~/components/SectionField.astro";
import CTAStrip from "~/components/CTAStrip.astro";

import heroPhoto from "~/assets/photos/hero-helicopter-hangar.jpg";
import productHospitalPhoto from "~/assets/photos/product-hospital-studio.webp";
import productDentistPhoto from "~/assets/photos/product-dentist-contents.jpg";
import fieldAmbulancePhoto from "~/assets/photos/field-ambulance-interior.jpg";
import kjerstiPhoto from "~/assets/photos/founder-kjersti-portrait.jpg";
import gregersPhoto from "~/assets/photos/founder-gregers-portrait.jpg";

const products = (await getCollection("products", ({ data }) => data.locale === "en"))
  .sort((a, b) => a.data.productNumber - b.data.productNumber);
---

<BaseLayout
  locale="en"
  altUrl="/"
  title="EmendaKit: Anaphylaxis kits designed and built in Norway"
  description="EmendaKit develops anaphylaxis emergency kits for hospitals, ambulances, maternity wards and dental clinics. Designed by an anaesthetist and a midwife. Packed to the Norwegian national protocol."
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="hero-tag">
          <span class="pulse"></span>
          Designed and built in Norway by healthcare professionals
        </span>
        <h1 class="display">
          An emergency kit designed <span>for when every second counts.</span>
        </h1>
        <p class="lede">
          Anaphylaxis kits developed by an anaesthetist and a midwife, for
          clinicians who don't have time to search. Waterproof. Shock-resistant.
          Packed to the Norwegian anaphylaxis protocol.
        </p>
      </div>
      <figure class="hero-photo">
        <Image
          src={heroPhoto}
          alt="Gregers Halvorsen in a flight suit in front of the air ambulance, with an EmendaKit anaphylaxis kit"
          widths={[720, 1080, 1440, 1920]}
          sizes="(min-width: 1024px) 50vw, 100vw"
          loading="eager"
          fetchpriority="high"
        />
        <figcaption>
          <span class="stamp">PHOTO 01 · Helicopter hangar · Helse Førde</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="products">
    <div class="container">
      <div class="products-head">
        <div>
          <div class="eyebrow">Two kits · one framework</div>
          <h2>Packed for the emergency.</h2>
        </div>
        <p>
          The same clinical framework, for two different uses. Both are packed to
          the national anaphylaxis protocol and delivered with a QR code to
          training films.
        </p>
      </div>
      <div class="product-grid">
        {products.map((p) => (
          <ProductCard
            title={p.data.title}
            summary={p.data.summary}
            href={`/en/product/${p.data.urlSlug}`}
            productNumber={p.data.productNumber}
            audience={p.data.audience}
            specs={p.data.specs.slice(0, 4)}
            image={p.data.productNumber === 1 ? productHospitalPhoto : productDentistPhoto}
            imageAlt={`${p.data.title} — ${p.data.descriptor}`}
            priceLabel={p.data.priceLabel}
            linkLabel="Product details"
            orderHref={`mailto:kjersti@emendakit.com?subject=${encodeURIComponent("Inquiry - " + p.data.title)}`}
            orderLabel="Order now"
          />
        ))}
      </div>
    </div>
  </section>

  <section class="field">
    <div class="container">
      <SectionField
        image={fieldAmbulancePhoto}
        imageAlt="Inside the air ambulance — patient care with the anaphylaxis kit within reach"
        imageStamp="PHOTO 04 · ambulance interior · patient care"
        eyebrow="Field experience · Helse Førde"
        title="Designed by a patient's side, not at a desk."
        body="EmendaKit was born on a ward, not in a meeting room. Every detail, from the adrenaline cover to the QR field on the side, comes from someone standing with a patient and wishing something were a little different."
        quote="“Innovation through knowledge and experience.”"
        attribution="EmendaKit's starting point, from day one."
      />
    </div>
  </section>

  <section class="founders">
    <div class="container">
      <div class="founders-head">
        <div class="eyebrow">Built by clinicians</div>
        <h2>Two voices from practice, one emergency kit with one logic.</h2>
      </div>
      <div class="founders-grid">
        <FounderCard
          image={kjerstiPhoto}
          imageAlt="Kjersti Grinde — midwife and co-founder of EmendaKit"
          imageStamp="PHOTO 05 · portrait · Kjersti Grinde"
          role="Co-founder · Midwife"
          name="Kjersti Grinde"
          bio="Midwife specialising in professional development and medical simulation. Designed EmendaKit for the departments she has worked in herself."
        />
        <FounderCard
          image={gregersPhoto}
          imageAlt="Gregers Halvorsen — anaesthetist and co-founder of EmendaKit"
          imageStamp="PHOTO 06 · portrait · Gregers Halvorsen"
          role="Co-founder · Anaesthetist"
          name="Gregers Halvorsen"
          bio="Anaesthetist at Helse Førde, with experience from air ambulance work and medical simulation."
          accent="cool"
        />
      </div>
    </div>
  </section>

  <CTAStrip
    title="Need a kit tailored to your department?"
    body="We co-design custom medical kits for maternity units, vaccination sites, ambulance services and departments with specific needs."
    primary={{ href: "mailto:kjersti@emendakit.com?subject=Request%20a%20design%20conversation", label: "Request a design conversation →" }}
    secondary={{ href: "mailto:kjersti@emendakit.com", label: "kjersti@emendakit.com" }}
  />
</BaseLayout>

<style>
  .container { max-width: 1320px; margin: 0 auto; padding: 0 32px; }

  /* ─── hero ─── */
  .hero { padding: 80px 0 64px; }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.25fr);
    gap: 56px;
    align-items: center;
  }
  @media (max-width: 960px) {
    .hero-grid { grid-template-columns: 1fr; gap: 32px; }
  }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--color-cyan-soft);
    color: var(--color-navy-deep);
    font-size: 13px; font-weight: 500;
    padding: 6px 14px 6px 8px;
    border-radius: var(--radius-pill);
    margin-bottom: 28px;
  }
  .hero-tag .pulse {
    width: 8px; height: 8px;
    background: var(--color-navy);
    border-radius: var(--radius-pill);
  }
  h1.display {
    font-family: var(--font-display);
    font-size: clamp(44px, 6vw, 76px);
    line-height: 0.98;
    letter-spacing: -0.035em;
    font-weight: 500;
    margin: 0 0 24px;
    max-width: 14ch;
  }
  h1.display span { color: var(--color-ink-3); }
  .lede {
    font-size: 19px; line-height: 1.55;
    color: var(--color-ink-2);
    max-width: 540px;
  }
  .hero-photo {
    margin: 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-ink);
    position: relative;
  }
  .hero-photo img {
    width: 100%; height: auto; display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
  .hero-photo figcaption {
    position: absolute;
    inset: auto 0 0 0;
    padding: 14px 18px;
    background: linear-gradient(180deg, transparent 0%, rgb(8 12 20 / 0.7) 100%);
  }
  .stamp {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.78);
  }

  /* ─── products ─── */
  .products {
    padding: 96px 0;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-cyan-soft) 100%);
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
  }
  .products-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
    align-items: end;
  }
  .products-head .eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-navy);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
  }
  .products-head h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 3.6vw, 44px);
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 0;
    max-width: 16ch;
  }
  .products-head p {
    font-size: 17px;
    line-height: 1.6;
    color: var(--color-ink-2);
    margin: 0;
    max-width: 50ch;
  }
  .product-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  @media (max-width: 800px) {
    .products-head,
    .product-grid { grid-template-columns: 1fr; }
    .products-head { gap: 20px; }
  }

  /* ─── field ─── */
  .field { padding: 96px 0; }

  /* ─── founders ─── */
  .founders {
    padding: 96px 0;
    background: var(--color-cyan-soft);
    border-top: 1px solid var(--color-rule);
  }
  .founders-head { text-align: center; margin-bottom: 48px; }
  .founders-head .eyebrow {
    font-family: var(--font-mono); font-size: 12px; color: var(--color-navy);
    text-transform: uppercase; letter-spacing: 0.12em;
    margin-bottom: 14px;
  }
  .founders-head h2 {
    font-family: var(--font-display); font-size: clamp(32px, 3.6vw, 44px); font-weight: 500;
    letter-spacing: -0.025em; line-height: 1.05;
    margin: 0 auto;
    max-width: 22ch;
  }
  .founders-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  @media (max-width: 800px) { .founders-grid { grid-template-columns: 1fr; } }
</style>
