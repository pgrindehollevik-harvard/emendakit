---
import BaseLayout from "~/layouts/BaseLayout.astro";
---

<BaseLayout
  locale="en"
  altUrl="/"
  title="EmendaKit — Anaphylaxis kits designed and produced in Norway"
  description="EmendaKit develops anaphylaxis emergency kits for hospitals, ambulances, maternity wards, and dental clinics. Designed by an anesthesiologist and a midwife. Packed to the Norwegian national protocol."
>
  <section style="padding: 80px 32px; max-width: 720px; margin: 0 auto;">
    <h1 style="font-family: var(--font-display); font-size: 56px; font-weight: 500; letter-spacing: -0.035em; line-height: 1; margin: 0 0 24px;">
      An anaphylaxis kit designed for every second.
    </h1>
    <p style="font-size: 19px; line-height: 1.55; color: var(--color-ink-2); margin: 0 0 24px;">
      EmendaKit develops anaphylaxis emergency kits for clinicians who don't have time to search.
      Waterproof. Shock-resistant. Packed to the Norwegian national anaphylaxis protocol.
    </p>
    <p style="font-size: 14px; color: var(--color-ink-3); font-style: italic;">
      English pages are scaffolded but require Kjersti's review before going live —
      see <code>I18N.md</code> in the repo.
    </p>
  </section>
</BaseLayout>
