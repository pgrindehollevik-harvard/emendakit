---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import SchemaProduct from "~/components/SchemaProduct.astro";
import SchemaFAQPage from "~/components/SchemaFAQPage.astro";
import CTAStrip from "~/components/CTAStrip.astro";

export async function getStaticPaths() {
  const products = await getCollection("products", ({ data }) => data.locale === "no");
  return products.map((product) => ({
    params: { slug: product.data.urlSlug },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await product.render();
const url = `/produkt/${product.data.urlSlug}`;
const altUrl = `/en/product/${product.data.altSlug}`;
---

<BaseLayout
  locale="no"
  altUrl={altUrl}
  title={`${product.data.title} — ${product.data.descriptor}`}
  description={product.data.summary}
>
  <SchemaProduct
    name={product.data.title}
    description={product.data.summary}
    url={url}
    productNumber={product.data.productNumber}
    audience={product.data.audience}
    deliveryTime={product.data.deliveryTime}
  />
  <SchemaFAQPage items={product.data.faq} />

  <article style="padding: 80px 32px; max-width: 880px; margin: 0 auto;">
    <p style="font-family: var(--font-mono); font-size: 12px; color: var(--color-navy); text-transform: uppercase; letter-spacing: 0.12em; margin: 0 0 14px;">
      №{product.data.productNumber.toString().padStart(2, "0")} · Anafylaksiskrin · {product.data.audience}
    </p>
    <h1 style="font-family: var(--font-display); font-size: clamp(36px, 4.4vw, 56px); font-weight: 500; letter-spacing: -0.03em; line-height: 1; margin: 0 0 18px;">
      {product.data.title}
    </h1>
    <p style="font-size: 19px; line-height: 1.55; color: var(--color-ink-2); margin: 0 0 32px;">
      {product.data.summary}
    </p>

    <h2 style="font-family: var(--font-display); font-size: 24px; font-weight: 500; margin: 32px 0 16px;">Spesifikasjoner</h2>
    <dl style="display: grid; grid-template-columns: 200px 1fr; gap: 12px 24px; font-size: 14px;">
      {product.data.specs.map((s) => (
        <>
          <dt style="font-family: var(--font-mono); color: var(--color-ink-3); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase;">{s.key}</dt>
          <dd style="margin: 0; color: var(--color-ink); font-weight: 500;">{s.value}</dd>
        </>
      ))}
    </dl>

    <Content />

    <h2 style="font-family: var(--font-display); font-size: 24px; font-weight: 500; margin: 48px 0 16px;">Spørsmål og svar</h2>
    <div style="display: grid; gap: 16px;">
      {product.data.faq.map((q) => (
        <details style="padding: 16px 0; border-top: 1px solid var(--color-rule);">
          <summary style="font-family: var(--font-display); font-size: 17px; font-weight: 500; cursor: pointer;">{q.question}</summary>
          <p style="font-size: 14px; line-height: 1.6; color: var(--color-ink-2); margin: 12px 0 0;">{q.answer}</p>
        </details>
      ))}
    </div>
  </article>

  <CTAStrip
    title={`Be om tilbud på ${product.data.title}`}
    body={`${product.data.priceLabel} · Leveringstid ${product.data.deliveryTime.toLowerCase()}. Send en kort beskrivelse av avdeling, antall skrin og ønsket leveringssted.`}
    primary={{
      href: `/kontakt?emne=${encodeURIComponent(product.data.title)}`,
      label: "Be om tilbud →",
    }}
    secondary={{
      href: "/opplaering",
      label: "Se opplæringsfilmer",
    }}
  />
</BaseLayout>
