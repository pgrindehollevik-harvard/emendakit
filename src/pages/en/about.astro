---
import { getCollection } from "astro:content";
import type { ImageMetadata } from "astro";
import BaseLayout from "~/layouts/BaseLayout.astro";
import FounderCard from "~/components/FounderCard.astro";
import CTAStrip from "~/components/CTAStrip.astro";
import kjerstiPhoto from "~/assets/photos/founder-kjersti-portrait.jpg";
import gregersPhoto from "~/assets/photos/founder-gregers-portrait.jpg";

const team = await getCollection("team", ({ data }) => data.locale === "en");
const photos: Record<string, ImageMetadata> = {
  "kjersti-grinde": kjerstiPhoto,
  "gregers-halvorsen": gregersPhoto,
};
const order = ["kjersti-grinde", "gregers-halvorsen"];
const founders = order
  .map((slug) => team.find((m) => m.data.urlSlug === slug))
  .filter((m): m is NonNullable<(typeof team)[number]> => Boolean(m));
---

<BaseLayout
  locale="en"
  altUrl="/om-oss"
  title="About — EmendaKit AS"
  description="EmendaKit AS was founded in 2022 in Florø, Norway, by healthcare professionals with experience in emergency medicine. We design and build anaphylaxis emergency kits."
>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">About · EmendaKit AS</p>
        <h1>Innovation through knowledge and experience.</h1>
      </div>
      <p class="lede">
        EmendaKit AS was founded in 2022 in Florø, on the west coast of Norway.
        The company was started by healthcare professionals who have worked in
        acute situations themselves, and who wanted more systematic,
        quality-assured ways to store medicines and medical equipment.
      </p>
    </div>
  </section>

  <section class="story" aria-labelledby="story-heading">
    <div class="container story-grid">
      <div>
        <p class="eyebrow">Background</p>
        <h2 id="story-heading">It started with an emergency.</h2>
      </div>
      <div class="story-copy">
        <p>
          The starting point was an incident in 2019, when a patient went into
          anaphylactic shock. The experience made it clear that emergency
          equipment had to be easier to find and faster to put to use.
        </p>
        <p>
          Kjersti Grinde, a midwife at the women's clinic at Helse Førde, looked
          for a better anaphylaxis kit for her own department. When she could not
          find a suitable solution on the market, she developed one herself, in
          collaboration with a resource group of doctors, nurses and pharmacists.
        </p>
        <p>
          After thorough development and testing, Helse Førde purchased 120 kits
          in spring 2023. The same year, anaesthetist Gregers Halvorsen became
          co-owner.
        </p>
      </div>
    </div>
  </section>

  <section class="name" aria-labelledby="name-heading">
    <div class="container name-grid">
      <div>
        <p class="eyebrow">The name</p>
        <h2 id="name-heading">Emenda + Kit</h2>
      </div>
      <p class="name-copy">
        Emenda comes from Old Norse and means to systematise, mend and put in
        order. Kit is English for box or case. The name describes what we do:
        bringing order and system to emergency readiness.
      </p>
    </div>
  </section>

  <section class="founders" aria-labelledby="founders-heading">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">The team</p>
        <h2 id="founders-heading">Two clinicians behind every kit.</h2>
      </div>
      <div class="founders-grid">
        {founders.map((member, i) => (
          <FounderCard
            image={photos[member.data.urlSlug]}
            imageAlt={`${member.data.name} — ${member.data.role}`}
            imageStamp={`Portrait · ${member.data.name}`}
            role={member.data.role}
            name={member.data.name}
            bio={member.data.bio}
            accent={i === 0 ? "warm" : "cool"}
          />
        ))}
      </div>
    </div>
  </section>

  <CTAStrip
    title="Want to know more about EmendaKit?"
    body="Get in touch for an informal conversation about anaphylaxis kits or custom solutions for your department."
    primary={{ href: "mailto:kjersti@emendakit.no?subject=About%20EmendaKit", label: "Email Kjersti →" }}
    secondary={{ href: "/en/products", label: "See the anaphylaxis kits" }}
  />
</BaseLayout>

<style>
  .container { max-width: 1180px; margin: 0 auto; padding: 0 32px; }
  .eyebrow {
    margin: 0 0 14px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--color-navy);
    text-transform: uppercase;
  }
  h1, h2 {
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }
  .hero { padding: 88px 0 72px; }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.75fr);
    gap: 56px;
    align-items: end;
  }
  .hero h1 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(42px, 6vw, 72px);
    line-height: 0.98;
  }
  .lede {
    margin: 0;
    color: var(--color-ink-2);
    font-size: 19px;
    line-height: 1.55;
  }
  .story, .name {
    padding: 78px 0;
    border-top: 1px solid var(--color-rule);
  }
  .story-grid, .name-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 1.1fr);
    gap: 56px;
    align-items: start;
  }
  .story h2, .name h2 {
    margin: 0;
    font-size: clamp(31px, 4vw, 46px);
    line-height: 1.04;
  }
  .story-copy p {
    margin: 0 0 18px;
    color: var(--color-ink-2);
    font-size: 17px;
    line-height: 1.65;
  }
  .story-copy p:last-child { margin-bottom: 0; }
  .name { background: var(--color-cyan-soft); }
  .name-copy {
    margin: 0;
    color: var(--color-ink-2);
    font-size: 17px;
    line-height: 1.65;
  }
  .founders {
    padding: 88px 0;
    border-top: 1px solid var(--color-rule);
  }
  .section-head { max-width: 720px; margin-bottom: 40px; }
  .section-head h2 {
    margin: 0;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.04;
  }
  .founders-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  @media (max-width: 860px) {
    .hero-grid, .story-grid, .name-grid, .founders-grid {
      grid-template-columns: 1fr;
    }
    .hero { padding-top: 64px; }
  }
</style>
