---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

type ProductSpec = {
  key: string;
  value: string;
};

interface Props {
  title: string;
  summary: string;
  href: string;
  productNumber: number;
  audience: string;
  specs?: readonly ProductSpec[];
  image?: ImageMetadata;
  imageAlt?: string;
  priceLabel?: string;
  linkLabel?: string;
  orderHref?: string;
  orderLabel?: string;
  variant?: "clinic" | "dental";
}

const {
  title,
  summary,
  href,
  productNumber,
  audience,
  specs = [],
  image,
  imageAlt = title,
  priceLabel = "Pris på forespørsel",
  linkLabel = "Produktdetaljer",
  orderHref,
  orderLabel = "Bestill nå",
  variant = productNumber === 1 ? "clinic" : "dental",
} = Astro.props;

const numberLabel = productNumber.toString().padStart(2, "0");
---

<article class="product-card">
  <div class:list={["product-img", `kit-${variant}`, { "has-photo": image }]}>
    {image ? (
      <Image src={image} alt={imageAlt} widths={[480, 720, 1080]} sizes="(min-width: 1024px) 40vw, 100vw" />
    ) : (
      <div class="kit-visual" aria-hidden="true">
        <span class="kit-lid"></span>
        <span class="kit-cell cell-one"></span>
        <span class="kit-cell cell-two"></span>
        <span class="kit-base"></span>
        <span class="kit-signal"></span>
      </div>
    )}
  </div>

  <div class="product-body">
    <div class="product-eyebrow">
      <span>№{numberLabel} · Anafylaksiskrin</span>
      <span class="pill">{audience}</span>
    </div>
    <h3>{title}</h3>
    <p>{summary}</p>
    {specs.length > 0 && (
      <ul class="product-spec">
        {specs.map((spec) => (
          <li>
            <span class="k">{spec.key}</span>
            <span class="v">{spec.value}</span>
          </li>
        ))}
      </ul>
    )}
    <div class="product-foot">
      <div class="product-actions">
        {orderHref && <a href={orderHref} class="order-btn">{orderLabel}</a>}
        <a href={href} class="detail-link">{linkLabel} →</a>
      </div>
      <span class="price">{priceLabel}</span>
    </div>
  </div>
</article>

<style>
  .product-card {
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .product-img {
    position: relative;
    aspect-ratio: 16 / 11;
    background:
      radial-gradient(ellipse 60% 50% at 50% 50%, color-mix(in srgb, var(--color-cyan) 12%, transparent) 0%, transparent 70%),
      linear-gradient(180deg, var(--color-navy-deep) 0%, var(--color-ink) 100%);
    overflow: hidden;
  }
  .product-img.kit-dental {
    background:
      radial-gradient(ellipse 60% 50% at 50% 50%, color-mix(in srgb, var(--color-cream) 14%, transparent) 0%, transparent 70%),
      linear-gradient(180deg, color-mix(in srgb, var(--color-navy) 65%, var(--color-ink)) 0%, var(--color-ink) 100%);
  }
  .product-img.has-photo {
    background: var(--color-surface);
  }
  .product-img img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 16px;
  }
  .kit-visual {
    position: absolute;
    inset: 16% 11%;
    border-radius: 14px;
    background: var(--color-navy);
    border: 2px solid var(--color-cyan);
    box-shadow: 0 24px 80px rgb(0 0 0 / 0.24);
  }
  .kit-dental .kit-visual {
    inset: 18% 16%;
  }
  .kit-visual span {
    position: absolute;
    border-radius: 6px;
    background: var(--color-navy-deep);
  }
  .kit-lid {
    top: 12%;
    left: 7%;
    right: 7%;
    height: 20%;
  }
  .kit-cell {
    top: 38%;
    height: 26%;
    width: 38%;
  }
  .cell-one {
    left: 7%;
  }
  .cell-two {
    right: 7%;
  }
  .kit-base {
    left: 7%;
    right: 7%;
    bottom: 6%;
    height: 22%;
  }
  .kit-signal {
    top: 6%;
    right: 5%;
    width: 18px;
    height: 18px;
    border-radius: var(--radius-pill);
    background: var(--color-signal);
  }
  .product-body {
    padding: 32px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .product-eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-navy);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 14px;
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
  }
  .product-eyebrow .pill {
    background: var(--color-cyan-soft);
    color: var(--color-navy-deep);
    font-family: var(--font-sans);
    font-size: 11px;
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    text-transform: none;
    letter-spacing: 0;
  }
  h3 {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0 0 14px;
  }
  p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-ink-2);
    margin: 0 0 20px;
  }
  .product-spec {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    display: grid;
    gap: 10px;
  }
  .product-spec li {
    display: flex;
    gap: 12px;
    align-items: baseline;
    font-size: 13px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--color-rule);
  }
  .product-spec li:last-child {
    border-bottom: none;
  }
  .product-spec .k {
    color: var(--color-ink-3);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    min-width: 110px;
  }
  .product-spec .v {
    color: var(--color-ink);
  }
  .product-foot {
    margin-top: auto;
    padding-top: 18px;
    border-top: 1px solid var(--color-rule);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .product-actions {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }
  .order-btn {
    background: var(--color-navy);
    color: var(--color-bg);
    border-radius: var(--radius-pill);
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 500;
  }
  .detail-link {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-navy);
    border-bottom: 1px solid var(--color-navy);
    padding-bottom: 2px;
  }
  .price {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-ink-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  @media (max-width: 520px) {
    .product-body {
      padding: 24px;
    }
    .product-spec li {
      display: grid;
      gap: 6px;
    }
  }
</style>
