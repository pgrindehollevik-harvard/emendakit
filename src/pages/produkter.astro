---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProductCard from "~/components/ProductCard.astro";
import CTAStrip from "~/components/CTAStrip.astro";
import productHospitalPhoto from "~/assets/photos/product-hospital-studio.webp";
import productDentistPhoto from "~/assets/photos/product-dentist-contents.jpg";

const products = (await getCollection("products", ({ data }) => data.locale === "no"))
  .sort((a, b) => a.data.productNumber - b.data.productNumber);
---

<BaseLayout
  locale="no"
  altUrl="/en/products"
  title="Anafylaksiskrin — EmendaKit Hospital og Dentist"
  description="To anafylaksiskrin på samme kliniske rammeverk: EmendaKit Hospital for helsepersonell og EmendaKit Dentist for tannhelsetjenesten. Pakket etter nasjonal anafylaksiprotokoll."
>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Anafylaksiskrin · To skrin · ett rammeverk</p>
        <h1>Anafylaksiskrin for norske helsetjenester.</h1>
      </div>
      <p class="lede">
        Samme kliniske rammeverk, til to ulike bruk. Begge er pakket etter
        nasjonal anafylaksiprotokoll, vanntette og støtsikre, og levert med
        QR-kode til opplæringsfilmer.
      </p>
    </div>
  </section>

  <section class="listing">
    <div class="container">
      <div class="product-grid">
        {products.map((p) => (
          <ProductCard
            title={p.data.title}
            summary={p.data.summary}
            href={`/produkt/${p.data.urlSlug}`}
            productNumber={p.data.productNumber}
            audience={p.data.audience}
            specs={p.data.specs.slice(0, 5)}
            image={p.data.productNumber === 1 ? productHospitalPhoto : productDentistPhoto}
            imageAlt={`${p.data.title} — ${p.data.descriptor}`}
            priceLabel={p.data.priceLabel}
            orderHref={`/kontakt?emne=${encodeURIComponent(p.data.title)}`}
          />
        ))}
      </div>
    </div>
  </section>

  <CTAStrip
    title="Trenger dere et skrin tilpasset deres avdeling?"
    body="Vi co-designer behovstilpassede medisinske skrin for fødeavdelinger, vaksinestasjoner, ambulansetjenester og avdelinger med spesielle behov."
    primary={{ href: "/tjenester/behovstilpasset", label: "Se behovstilpasset →" }}
    secondary={{ href: "mailto:kjersti@emendakit.com", label: "kjersti@emendakit.com" }}
  />
</BaseLayout>

<style>
  .container { max-width: 1320px; margin: 0 auto; padding: 0 32px; }
  .eyebrow {
    margin: 0 0 14px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--color-navy);
    text-transform: uppercase;
  }
  .hero { padding: 88px 0 56px; }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.75fr);
    gap: 56px;
    align-items: end;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    max-width: 760px;
    margin: 0;
    font-size: clamp(42px, 6vw, 72px);
    line-height: 0.98;
  }
  .lede {
    margin: 0;
    color: var(--color-ink-2);
    font-size: 19px;
    line-height: 1.55;
  }
  .listing { padding: 24px 0 96px; }
  .product-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  @media (max-width: 860px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero { padding-top: 64px; }
  }
  @media (max-width: 800px) {
    .product-grid { grid-template-columns: 1fr; }
  }
</style>
