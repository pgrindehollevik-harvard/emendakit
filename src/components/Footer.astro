---
import { SITE, type Locale } from "~/lib/site";
import LangSwitch from "./LangSwitch.astro";
import logo from "~/assets/logo/emendakit-logo-blue-on-grey.png";

interface Props {
  locale: Locale;
  altUrl: string;
}

const { locale, altUrl } = Astro.props;
const t = locale === "no";

const productLinks = t
  ? [
      { href: "/produkt/emendakit-hospital", label: "EmendaKit Hospital" },
      { href: "/produkt/emendakit-dentist", label: "EmendaKit Dentist" },
      { href: "/tjenester/behovstilpasset", label: "Behovstilpasset" },
    ]
  : [
      { href: "/en/product/emendakit-hospital", label: "EmendaKit Hospital" },
      { href: "/en/product/emendakit-dentist", label: "EmendaKit Dentist" },
      { href: "/en/services/custom-kit", label: "Custom kits" },
    ];

const companyLinks = t
  ? [
      { href: "/om-oss", label: "Om oss" },
      { href: "/opplaering", label: "Klinisk grunnlag" },
      { href: "/mediaomtale", label: "Mediaomtale" },
      { href: "/samarbeidspartnere", label: "Samarbeidspartnere" },
    ]
  : [
      { href: "/en/about", label: "About" },
      { href: "/en/training", label: "Clinical reference" },
      { href: "/en/press", label: "Press" },
      { href: "/en/partners", label: "Partners" },
    ];

const contactLinks = [
  { href: `mailto:${SITE.email}`, label: SITE.email },
  {
    href: `mailto:${SITE.email}?subject=${encodeURIComponent(t ? "Be om tilbud" : "Request a quote")}`,
    label: t ? "Be om tilbud" : "Request a quote",
  },
  { href: t ? "/opplaering" : "/en/training", label: t ? "Opplæringsfilmer" : "Training videos" },
];
---

<footer>
  <div class="container">
    <div class="foot">
      <div>
        <a href={t ? "/" : "/en/"} class="brand"><img src={logo.src} alt="EmendaKit" width="160" height="28" /></a>
        <p class="lede">
          {t
            ? "EmendaKit AS · Innovasjon gjennom kunnskap og erfaring. Designet, testet og produsert i Norge."
            : "EmendaKit AS · Innovation through knowledge and experience. Designed, tested and produced in Norway."}
        </p>
      </div>
      <div>
        <h4>{t ? "Produkter" : "Products"}</h4>
        <ul>{productLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
      </div>
      <div>
        <h4>{t ? "Selskap" : "Company"}</h4>
        <ul>{companyLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
      </div>
      <div>
        <h4>{t ? "Kontakt" : "Contact"}</h4>
        <ul>{contactLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
      </div>
    </div>
    <div class="colophon">
      <span>© {new Date().getFullYear()} EmendaKit AS · {t ? "Designet i Norge" : "Designed in Norway"}</span>
      <LangSwitch current={locale} altUrl={altUrl} variant="footer" />
    </div>
  </div>
</footer>

<style>
  footer {
    padding: 48px 0 32px;
    border-top: 1px solid var(--color-rule);
    background: var(--color-bg);
  }
  .container { max-width: 1320px; margin: 0 auto; padding: 0 32px; }
  .foot {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 32px;
  }
  .foot h4 {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-3);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 16px;
  }
  .foot ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 10px; }
  .foot a {
    color: var(--color-ink);
    font-size: 14px;
    text-decoration: none;
    transition: color 120ms var(--ease-soft);
  }
  .foot a:hover {
    color: var(--color-navy);
  }
  .foot .lede {
    color: var(--color-ink-2);
    font-size: 14px;
    line-height: 1.55;
    max-width: 32ch;
    margin-top: 12px;
  }
  .foot .brand img {
    height: 28px;
    width: auto;
  }
  .colophon {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--color-rule);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--color-ink-3);
  }
  @media (max-width: 840px) {
    .foot {
      grid-template-columns: 1fr 1fr;
    }
    .foot > div:first-child {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 560px) {
    footer {
      padding: 40px 0 28px;
    }
    .container {
      padding: 0 20px;
    }
    .foot {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .colophon {
      align-items: flex-start;
      flex-direction: column;
      gap: 14px;
    }
  }
</style>
