---
import { SITE, type Locale } from "~/lib/site";

interface Props {
  title: string;
  description: string;
  locale: Locale;
  altUrl?: string;            // path to the equivalent page in the other locale
  ogImage?: string;
  canonical?: string;
}

const { title, description, locale, altUrl, ogImage, canonical } = Astro.props;
// Norwegian lives on emendakit.no, English on emendakit.com — keep SEO signals on the right domain.
const NO_ORIGIN = "https://emendakit.no";
const EN_ORIGIN = "https://emendakit.com";
const path = Astro.url.pathname;
const noHref = NO_ORIGIN + (locale === "no" ? path : (altUrl ?? "/"));
const enHref = EN_ORIGIN + (locale === "en" ? path : (altUrl ?? "/en"));
const langTag = locale === "no" ? "nb-NO" : "en-US";
const url = canonical ?? (locale === "no" ? noHref : enHref);
const origin = locale === "no" ? NO_ORIGIN : EN_ORIGIN;
const fullOgImage = ogImage?.startsWith("http") ? ogImage : origin + (ogImage ?? "/og-default.jpg");
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={url} />
<meta name="theme-color" content="#1e3a5f" />

{/* hreflang — domain-per-language (no = .no, en = .com) for AEO/SEO discoverability */}
<link rel="alternate" hreflang="nb-NO" href={noHref} />
<link rel="alternate" hreflang="en-US" href={enHref} />
<link rel="alternate" hreflang="x-default" href={enHref} />

{/* OpenGraph */}
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={url} />
<meta property="og:locale" content={langTag.replace("-", "_")} />
<meta property="og:locale:alternate" content={locale === "no" ? "en_US" : "nb_NO"} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:image" content={fullOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="EmendaKit anafylaksiskrin i klinisk luftambulanse-miljø" />

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullOgImage} />
