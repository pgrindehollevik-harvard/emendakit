---
import type { Locale } from "~/lib/site";
import LangSwitch from "./LangSwitch.astro";
import logo from "~/assets/logo/emendakit-logo.png";

interface Props {
  locale: Locale;
  altUrl: string;
}

const { locale, altUrl } = Astro.props;
const currentPath = Astro.url.pathname;

const nav = locale === "no"
  ? [
      { href: "/produkter", label: "Anafylaksiskrin", active: currentPath.startsWith("/produkt") || currentPath === "/produkter" },
      { href: "/tjenester", label: "Tjenester", active: currentPath.startsWith("/tjenester") },
      { href: "/opplaering", label: "Opplæringsfilmer", active: currentPath.startsWith("/opplaering") },
      { href: "/om-oss", label: "Om oss", active: currentPath.startsWith("/om-oss") },
    ]
  : [
      { href: "/en/products", label: "Anaphylaxis kits", active: currentPath.startsWith("/en/product") || currentPath === "/en/products" },
      { href: "/en/services", label: "Services", active: currentPath.startsWith("/en/services") },
      { href: "/en/training", label: "Training videos", active: currentPath.startsWith("/en/training") },
      { href: "/en/about", label: "About", active: currentPath.startsWith("/en/about") },
    ];

const ctaLabel = locale === "no" ? "Be om tilbud" : "Request a quote";
const ctaHref = locale === "no" ? "/kontakt" : "/en/contact";
const menuLabel = locale === "no" ? "Meny" : "Menu";
---

<header>
  <div class="container nav">
    <a href={locale === "no" ? "/" : "/en/"} class="brand" aria-label="EmendaKit hjem">
      <img src={logo.src} alt="EmendaKit" width="160" height="28" />
    </a>
    <nav class="nav-links" aria-label="Hovedmeny">
      {nav.map((item) => (
        <a href={item.href} class={item.active ? "current" : ""} aria-current={item.active ? "page" : undefined}>
          {item.label}
        </a>
      ))}
    </nav>
    <div class="nav-spacer"></div>
    <LangSwitch current={locale} altUrl={altUrl} variant="header" />
    <a href={ctaHref} class="cta-button">
      <span class="dot"></span> {ctaLabel}
    </a>
    <button class="menu-toggle" type="button" aria-label={menuLabel} aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav class="mobile-menu" id="mobile-menu" aria-label={menuLabel}>
    {nav.map((item) => (
      <a href={item.href} class={item.active ? "current" : ""} aria-current={item.active ? "page" : undefined}>
        {item.label}
      </a>
    ))}
    <a href={ctaHref} class="mobile-cta"><span class="dot"></span> {ctaLabel}</a>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(250, 250, 247, 0.85);
    backdrop-filter: blur(14px) saturate(1.4);
    border-bottom: 1px solid var(--color-rule);
  }
  .container {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 40px;
    padding: 18px 0;
  }
  .brand {
    flex: 0 0 auto;
  }
  .brand img {
    height: 28px;
    width: auto;
    display: block;
  }
  .nav-links {
    display: flex;
    gap: 28px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-ink-2);
  }
  .nav-links a {
    text-decoration: none;
    transition: color 120ms var(--ease-soft);
  }
  .nav-links a:hover,
  .nav-links a.current {
    color: var(--color-navy);
  }
  .nav-spacer { flex: 1; }
  .cta-button {
    background: var(--color-navy);
    color: var(--color-bg);
    border-radius: var(--radius-pill);
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .cta-button .dot {
    width: 6px;
    height: 6px;
    background: var(--color-cyan);
    border-radius: var(--radius-pill);
  }

  /* mobile menu — hidden on desktop, no effect on desktop layout */
  .menu-toggle { display: none; }
  .mobile-menu { display: none; }

  @media (max-width: 980px) {
    .nav {
      gap: 20px;
    }
    .nav-links {
      display: none;
    }
    .menu-toggle {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      flex: 0 0 auto;
      width: 40px;
      height: 40px;
      padding: 9px;
      background: none;
      border: none;
      cursor: pointer;
    }
    .menu-toggle span {
      display: block;
      width: 22px;
      height: 2px;
      border-radius: 2px;
      background: var(--color-navy);
      transition: transform 220ms var(--ease-soft), opacity 160ms var(--ease-soft);
    }
    .menu-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .menu-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
    .menu-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    .mobile-menu {
      display: flex;
      flex-direction: column;
      max-height: 0;
      overflow: hidden;
      padding: 0 32px;
      transition: max-height 300ms var(--ease-soft);
    }
    .mobile-menu.open {
      max-height: 80vh;
    }
    .mobile-menu a {
      font-size: 17px;
      font-weight: 500;
      color: var(--color-ink);
      text-decoration: none;
      padding: 17px 2px;
      border-bottom: 1px solid var(--color-rule);
    }
    .mobile-menu a.current {
      color: var(--color-navy);
    }
    .mobile-menu .mobile-cta {
      border-bottom: none;
      width: fit-content;
      margin: 20px 0 24px;
      background: var(--color-navy);
      color: var(--color-bg);
      border-radius: var(--radius-pill);
      padding: 14px 24px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .mobile-menu .mobile-cta .dot {
      width: 6px;
      height: 6px;
      background: var(--color-cyan);
      border-radius: var(--radius-pill);
    }
  }
  @media (max-width: 640px) {
    .container {
      padding: 0 20px;
    }
    .nav {
      padding: 14px 0;
      gap: 12px;
    }
    .cta-button {
      display: none;
    }
    .mobile-menu {
      padding-left: 20px;
      padding-right: 20px;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".menu-toggle");
  const menu = document.getElementById("mobile-menu");
  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const open = menu.classList.toggle("open");
      toggle.setAttribute("aria-expanded", String(open));
    });
    window.addEventListener("resize", () => {
      if (window.innerWidth > 980 && menu.classList.contains("open")) {
        menu.classList.remove("open");
        toggle.setAttribute("aria-expanded", "false");
      }
    });
  }
</script>
