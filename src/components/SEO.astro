---
import { SITE, type Locale } from "~/lib/site";

interface Props {
  title: string;
  description: string;
  locale: Locale;
  altUrl?: string;            // path to the equivalent page in the other locale
  ogImage?: string;
  canonical?: string;
}

const { title, description, locale, altUrl, ogImage, canonical } = Astro.props;
const url = canonical ?? new URL(Astro.url.pathname, SITE.url).href;
const altLocale = locale === "no" ? "en" : "no";
const langTag = locale === "no" ? "nb-NO" : "en-US";
const altLangTag = altLocale === "no" ? "nb-NO" : "en-US";
const fullOgImage = new URL(ogImage ?? "/og-default.jpg", SITE.url).href;
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={url} />
<meta name="theme-color" content="#1e3a5f" />

{/* hreflang — required for AEO bilingual discoverability */}
<link rel="alternate" hreflang={langTag} href={url} />
{altUrl && (
  <link rel="alternate" hreflang={altLangTag} href={new URL(altUrl, SITE.url).href} />
)}
<link rel="alternate" hreflang="x-default" href={SITE.url + "/"} />

{/* OpenGraph */}
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={url} />
<meta property="og:locale" content={langTag.replace("-", "_")} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:image" content={fullOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="EmendaKit anafylaksiskrin i klinisk luftambulanse-miljø" />

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullOgImage} />
