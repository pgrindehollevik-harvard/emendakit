---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Video, { type VideoFilm } from "~/components/Video.astro";
import { readFileSync } from "node:fs";
import { resolve } from "node:path";

const root = resolve(import.meta.dirname, "../../public/videos");

function loadTranscript(name: string): string {
  return readFileSync(resolve(root, `${name}.txt`), "utf8")
    .split("\n")
    .map((l) => l.replace(/^ /, "").trim())
    .filter(Boolean)
    .join("\n");
}

const films: VideoFilm[] = [
  {
    id: "opplaeringsfilm",
    title: "Opplæringsfilm — anafylaksi i klinisk situasjon",
    duration: "PT5M10S",
    durationLabel: "5:10",
    uploadDate: "2026-04-29",
    inLanguage: "nb-NO",
    description:
      "Trinn-for-trinn-håndtering av en anafylaktisk reaksjon på sengepost. Intensivsykepleier varsler lege, henter anafylaksiskrinet, gir adrenalin etter prosedyre.",
    poster: "/videos/opplaeringsfilm-poster.jpg",
    sources: [{ src: "https://pjcuyzjhnieellii.public.blob.vercel-storage.com/videos/opplaeringsfilm-BhjJYC6hLwmYxOzLcCj0zvjZtuHiz9.mp4", type: "video/mp4" }],
    subtitles: { src: "/videos/opplaeringsfilm.vtt", srclang: "no", label: "Norsk" },
    hasBurnedInSubtitles: false,
    transcript: loadTranscript("opplaeringsfilm"),
  },
  {
    id: "demo",
    title: "Skrinet — innhold, oppbygning og bruk",
    duration: "PT3M35S",
    durationLabel: "3:35",
    uploadDate: "2026-04-29",
    inLanguage: "nb-NO",
    description:
      "Gjennomgang av anafylaksiskrinets fysiske oppbygning, innhold (medikamenter og hjelpemidler), flytskjema, QR-kode, samt rengjøringsanvisning.",
    poster: "/videos/demo-poster.jpg",
    sources: [{ src: "https://pjcuyzjhnieellii.public.blob.vercel-storage.com/videos/demo-e3kscyWI2RKE6KllR0VAevpib5S6RR.mp4", type: "video/mp4" }],
    subtitles: { src: "/videos/demo.vtt", srclang: "no", label: "Norsk" },
    hasBurnedInSubtitles: true,
    transcript: loadTranscript("demo"),
  },
];
---

<BaseLayout
  locale="no"
  altUrl="/en/training/"
  title="Opplæringsfilmer — EmendaKit"
  description="To opplæringsfilmer om håndtering av anafylaksi og bruk av EmendaKit anafylaksiskrin. Med fullstendige transkripsjoner."
>
  <section class="intro">
    <div class="container">
      <div class="eyebrow">Opplæring · Anafylaksi</div>
      <h1>Opplæringsfilmer</h1>
      <p class="lede">
        To korte filmer for klinikere: håndtering av en anafylaktisk reaksjon,
        og en gjennomgang av skrinets innhold og bruk. QR-koden på skrinet peker
        hit.
      </p>
    </div>
  </section>

  {films.map((film) => (
    <section class="film-shell">
      <div class="container">
        <Video
          film={film}
          indexLabel={`№ ${film.id === "opplaeringsfilm" ? "01" : "02"}`}
          showTranscript={false}
        />
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .container { max-width: 1080px; margin: 0 auto; padding: 0 32px; }
  .intro { padding: 80px 0 32px; }
  .intro .eyebrow {
    font-family: var(--font-mono);
    font-size: 12px; color: var(--color-navy);
    text-transform: uppercase; letter-spacing: 0.1em;
    margin-bottom: 18px;
  }
  .intro h1 {
    font-family: var(--font-display);
    font-size: clamp(40px, 5.5vw, 64px); font-weight: 500;
    letter-spacing: -0.03em; line-height: 0.98;
    margin: 0 0 22px;
  }
  .intro .lede {
    font-size: 18px; line-height: 1.55;
    color: var(--color-ink-2);
    max-width: 620px;
    margin: 0;
  }

  .film-shell { padding: 0; }
</style>
