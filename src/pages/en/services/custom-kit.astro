---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";

const services = await getCollection(
  "services",
  ({ data }) => data.locale === "en",
);
const service = services.find((entry) => entry.slug === "custom-kit");

if (!service) {
  throw new Error("Missing English service entry: custom-kit");
}

const { Content } = await service.render();
const process = [
  {
    number: "01",
    title: "Design conversation",
    text: "We go through the scenarios, procedures, rooms and deviations that make your need concrete.",
  },
  {
    number: "02",
    title: "Packing proposal",
    text: "We sketch contents, layout, labelling and how the kit should support the workflow during an acute event.",
  },
  {
    number: "03",
    title: "Pilot in the clinic",
    text: "One or a few units are tested by the team that will actually use the kit.",
  },
  {
    number: "04",
    title: "Adjustment and delivery",
    text: "Experience from the pilot informs the final packing, labelling and delivery of finished kits.",
  },
];
---

<BaseLayout
  locale="en"
  altUrl={`/tjenester/${service.data.altSlug}`}
  title={`${service.data.title} — EmendaKit`}
  description={service.data.summary}
>
  <article>
    <section class="hero">
      <div class="container hero-grid">
        <div>
          <p class="eyebrow">Custom kits · {service.data.audience}</p>
          <h1>{service.data.title}</h1>
        </div>
        <div class="hero-card">
          <p>{service.data.summary}</p>
          <a
            href={`mailto:kjersti@emendakit.com?subject=${encodeURIComponent("Design conversation about a custom kit")}`}
          >
            Request a design conversation →
          </a>
        </div>
      </div>
    </section>

    <section class="audience" aria-labelledby="audience-heading">
      <div class="container audience-grid">
        <div>
          <p class="eyebrow">Who it's for</p>
          <h2 id="audience-heading">When the standard pack isn't precise enough.</h2>
        </div>
        <div class="audience-copy">
          <p>
            Custom medical kits are for departments where emergency readiness
            must mirror a particular patient group, procedure or physical
            workflow. That can be maternity units, vaccination sites, emergency
            departments, ambulance services or units with specific requirements
            for contents and labelling.
          </p>
          <ul>
            <li>A fixed place for every medication and component.</li>
            <li>Labelling that supports your procedure under time pressure.</li>
            <li>The option of a pilot before final delivery.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="process" aria-labelledby="process-heading">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">How we work</p>
          <h2 id="process-heading">
            From clinical need to a finished, packed kit.
          </h2>
        </div>

        <ol class="process-list">
          {
            process.map((step) => (
              <li>
                <span>{step.number}</span>
                <div>
                  <h3>{step.title}</h3>
                  <p>{step.text}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section class="content-note" aria-labelledby="source-heading">
      <div class="container source-grid">
        <div>
          <p class="eyebrow">From the service description</p>
          <h2 id="source-heading">
            The framework is EmendaKit. The contents are yours.
          </h2>
        </div>
        <div class="mdx-content">
          <Content />
        </div>
      </div>
    </section>

    <section class="cta">
      <div class="container cta-grid">
        <div>
          <p class="eyebrow">Next step</p>
          <h2>Send Kjersti a short description of the need.</h2>
        </div>
        <div>
          <p>
            The design conversation is free and without obligation. Write which
            department it concerns, which scenarios the kit should support, and
            whether you want one pilot or several units.
          </p>
          <a
            href={`mailto:kjersti@emendakit.com?subject=${encodeURIComponent("Custom medical kit")}`}
            class="button"
          >
            kjersti@emendakit.com →
          </a>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .eyebrow {
    margin: 0 0 14px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--color-navy);
    text-transform: uppercase;
  }

  .hero {
    padding: 84px 0 76px;
  }

  .hero-grid,
  .audience-grid,
  .source-grid,
  .cta-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.78fr);
    gap: 56px;
    align-items: start;
  }

  h1,
  h2,
  h3 {
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }

  h1 {
    max-width: 780px;
    margin: 0;
    font-size: clamp(42px, 6vw, 72px);
    line-height: 0.98;
  }

  h2 {
    margin: 0;
    font-size: clamp(31px, 4vw, 48px);
    line-height: 1.04;
  }

  h3 {
    margin: 0 0 8px;
    font-size: 22px;
    letter-spacing: -0.015em;
  }

  .hero-card {
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    padding: 30px;
  }

  .hero-card p,
  .audience-copy p,
  .cta p {
    margin: 0;
    color: var(--color-ink-2);
    font-size: 17px;
    line-height: 1.65;
  }

  .hero-card a,
  .button {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    margin-top: 24px;
    border-radius: var(--radius-pill);
    background: var(--color-navy);
    color: var(--color-bg);
    padding: 14px 22px;
    font-weight: 500;
  }

  .audience,
  .content-note {
    padding: 78px 0;
    border-top: 1px solid var(--color-rule);
  }

  .audience-copy ul {
    display: grid;
    gap: 12px;
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
  }

  .audience-copy li {
    border-top: 1px solid var(--color-rule);
    padding-top: 12px;
    color: var(--color-ink);
    font-size: 15px;
  }

  .process {
    padding: 78px 0 86px;
    border-top: 1px solid var(--color-rule);
    background: var(--color-cyan-soft);
  }

  .section-head {
    max-width: 720px;
    margin-bottom: 34px;
  }

  .process-list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .process-list li {
    min-height: 250px;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    padding: 24px;
  }

  .process-list span {
    display: block;
    margin-bottom: 44px;
    font-family: var(--font-mono);
    color: var(--color-navy);
    font-size: 12px;
    letter-spacing: 0.12em;
  }

  .process-list p {
    margin: 0;
    color: var(--color-ink-2);
    font-size: 14px;
    line-height: 1.6;
  }

  .mdx-content {
    color: var(--color-ink-2);
    font-size: 16px;
    line-height: 1.65;
  }

  .mdx-content :global(h2) {
    margin: 0 0 14px;
    font-family: var(--font-display);
    color: var(--color-ink);
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .mdx-content :global(h2:not(:first-child)) {
    margin-top: 34px;
  }

  .mdx-content :global(p) {
    margin: 0 0 18px;
  }

  .mdx-content :global(ol) {
    margin: 0 0 18px;
    padding-left: 1.2rem;
  }

  .mdx-content :global(li) {
    margin-bottom: 9px;
  }

  .cta {
    padding: 74px 0;
    border-top: 1px solid var(--color-rule);
    background: #111b2b;
    color: var(--color-bg);
  }

  .cta .eyebrow {
    color: var(--color-cyan);
  }

  .cta h2 {
    color: var(--color-bg);
  }

  .cta p {
    color: rgba(250, 250, 247, 0.78);
  }

  .cta .button {
    background: var(--color-bg);
    color: var(--color-navy);
  }

  @media (max-width: 920px) {
    .hero-grid,
    .audience-grid,
    .source-grid,
    .cta-grid,
    .process-list {
      grid-template-columns: 1fr;
    }

    .hero {
      padding-top: 64px;
    }

    .process-list li {
      min-height: 0;
    }

    .process-list span {
      margin-bottom: 28px;
    }
  }
</style>
