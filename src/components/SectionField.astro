---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  eyebrow: string;
  title: string;
  body: string;
  quote?: string;
  attribution?: string;
  image?: ImageMetadata;
  imageAlt?: string;
  imageStamp?: string;
}

const { eyebrow, title, body, quote, attribution, image, imageAlt = "", imageStamp } = Astro.props;
---

<div class="field-grid">
  <figure class="field-photo">
    {image && (
      <Image src={image} alt={imageAlt} widths={[640, 960, 1280]} sizes="(min-width: 1024px) 55vw, 100vw" />
    )}
    {!image && (
      <>
        <span class="figure-primary" aria-hidden="true"></span>
        <span class="figure-secondary" aria-hidden="true"></span>
      </>
    )}
    {imageStamp && <span class="photo-stamp">{imageStamp}</span>}
  </figure>
  <div class="field-copy">
    <div class="eyebrow">{eyebrow}</div>
    <h2>{title}</h2>
    <p>{body}</p>
    {quote && <blockquote>{quote}</blockquote>}
    {attribution && <div class="attrib">{attribution}</div>}
  </div>
</div>

<style>
  .field-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .field-photo {
    position: relative;
    margin: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: linear-gradient(180deg, var(--color-navy-deep) 0%, var(--color-ink) 100%);
  }
  .field-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .photo-stamp {
    position: absolute;
    bottom: 20px;
    left: 20px;
    right: 20px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.62);
  }
  .figure-primary {
    position: absolute;
    left: 22%;
    top: 30%;
    width: 28%;
    height: 50%;
    background: linear-gradient(180deg, var(--color-signal) 0%, color-mix(in srgb, var(--color-signal) 65%, var(--color-ink)) 100%);
    clip-path: polygon(40% 0, 60% 0, 70% 100%, 30% 100%);
    opacity: 0.85;
  }
  .figure-secondary {
    position: absolute;
    right: 22%;
    top: 60%;
    width: 16%;
    height: 26%;
    background: linear-gradient(180deg, color-mix(in srgb, var(--color-navy) 44%, var(--color-bg)) 0%, var(--color-navy-deep) 100%);
    border-radius: 4px;
    opacity: 0.7;
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-navy);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 18px;
  }
  h2 {
    font-family: var(--font-display);
    font-size: clamp(30px, 3.4vw, 40px);
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 0 0 22px;
  }
  p {
    font-size: 17px;
    line-height: 1.6;
    color: var(--color-ink-2);
    margin: 0 0 18px;
  }
  blockquote {
    font-family: var(--font-display);
    font-size: 22px;
    line-height: 1.45;
    font-style: italic;
    color: var(--color-ink);
    border-left: 3px solid var(--color-navy);
    padding: 4px 0 4px 20px;
    margin: 28px 0 8px;
  }
  .attrib {
    font-size: 13px;
    color: var(--color-ink-3);
    margin-top: 8px;
  }
  @media (max-width: 960px) {
    .field-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
