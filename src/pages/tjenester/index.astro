---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";

const services = await getCollection(
  "services",
  ({ data }) => data.locale === "no",
);
const customService = services.find(
  (service) => service.slug === "behovstilpasset",
);

if (!customService) {
  throw new Error("Missing Norwegian service entry: behovstilpasset");
}

const serviceCards = [customService];
---

<BaseLayout
  locale="no"
  altUrl="/en/services"
  title="Tjenester — behovstilpassede medisinske skrin fra EmendaKit"
  description="EmendaKit co-designer behovstilpassede medisinske akuttskrin for helseforetak, fødeavdelinger, vaksinestasjoner og avdelinger med spesielle behov."
>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Tjenester · Medisinske akuttskrin</p>
        <h1>Behovstilpassede skrin for avdelinger med andre krav.</h1>
      </div>
      <p class="lede">
        Når standardskrinet ikke dekker behovet deres, bruker vi
        EmendaKit-rammeverket til å designe et skrin rundt deres prosedyrer, rom
        og kliniske scenarioer.
      </p>
    </div>
  </section>

  <section class="service-list" aria-labelledby="service-heading">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Ett rammeverk · flere kliniske kontekster</p>
        <h2 id="service-heading">Tjenester</h2>
      </div>

      <div class="cards">
        {
          serviceCards.map((service) => (
            <article class="service-card">
              <div class="card-media" aria-hidden="true">
                <span class="media-label">Designsamtale</span>
                <span class="media-line" />
                <span class="media-label">Pilot</span>
                <span class="media-line" />
                <span class="media-label">Levering</span>
              </div>
              <div class="card-body">
                <p class="card-kicker">{service.data.audience}</p>
                <h3>{service.data.title}</h3>
                <p>{service.data.summary}</p>
                <a href="/tjenester/behovstilpasset" class="card-link">
                  Se hvordan vi jobber →
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="quote-band">
    <div class="container quote-grid">
      <div>
        <p class="eyebrow">Praktisk startpunkt</p>
        <h2>Start med en gratis designsamtale.</h2>
      </div>
      <div>
        <p>
          Ta med scenarioene, avvikene og kravene som gjør avdelingen deres litt
          annerledes. Vi skisserer et forslag før dere bestemmer dere for pilot.
        </p>
        <a href="/kontakt?emne=Behovstilpasset%20skrin" class="button">
          Be om designsamtale →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .eyebrow {
    margin: 0 0 14px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--color-navy);
    text-transform: uppercase;
  }

  .hero {
    padding: 88px 0 72px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.75fr);
    gap: 56px;
    align-items: end;
  }

  .hero h1,
  .section-head h2,
  .quote-band h2 {
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }

  .hero h1 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(42px, 6vw, 72px);
    line-height: 0.98;
  }

  .lede {
    margin: 0;
    color: var(--color-ink-2);
    font-size: 19px;
    line-height: 1.55;
  }

  .service-list {
    padding: 76px 0 88px;
    border-top: 1px solid var(--color-rule);
    background: var(--color-cyan-soft);
  }

  .section-head {
    max-width: 720px;
    margin-bottom: 32px;
  }

  .section-head h2 {
    margin: 0;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.04;
  }

  .cards {
    display: grid;
    gap: 24px;
  }

  .service-card {
    display: grid;
    grid-template-columns: minmax(260px, 0.85fr) minmax(0, 1.15fr);
    overflow: hidden;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-xl);
    background: var(--color-surface);
  }

  .card-media {
    display: grid;
    align-content: center;
    gap: 18px;
    min-height: 320px;
    padding: 40px;
    background: linear-gradient(180deg, #17243a 0%, #09111e 100%);
    color: var(--color-bg);
  }

  .media-label {
    width: fit-content;
    border: 1px solid rgba(141, 196, 205, 0.45);
    border-radius: var(--radius-pill);
    padding: 9px 14px;
    font-size: 13px;
    font-weight: 500;
  }

  .media-line {
    width: 1px;
    height: 42px;
    margin-left: 18px;
    background: rgba(141, 196, 205, 0.55);
  }

  .card-body {
    padding: 42px;
  }

  .card-kicker {
    margin: 0 0 12px;
    color: var(--color-ink-3);
    font-size: 13px;
  }

  .card-body h3 {
    margin: 0 0 16px;
    font-family: var(--font-display);
    font-size: clamp(28px, 3.2vw, 40px);
    font-weight: 500;
    letter-spacing: -0.025em;
  }

  .card-body p {
    max-width: 680px;
    margin: 0 0 26px;
    color: var(--color-ink-2);
    font-size: 16px;
    line-height: 1.65;
  }

  .card-link {
    color: var(--color-navy);
    font-weight: 600;
  }

  .quote-band {
    padding: 72px 0;
    border-top: 1px solid var(--color-rule);
  }

  .quote-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(280px, 0.8fr);
    gap: 48px;
    align-items: start;
  }

  .quote-band h2 {
    margin: 0;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.04;
  }

  .quote-band p:not(.eyebrow) {
    margin: 0 0 24px;
    color: var(--color-ink-2);
    font-size: 16px;
    line-height: 1.65;
  }

  .button {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-pill);
    background: var(--color-navy);
    color: var(--color-bg);
    padding: 14px 22px;
    font-weight: 500;
  }

  @media (max-width: 860px) {
    .hero-grid,
    .service-card,
    .quote-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      padding-top: 64px;
    }

    .card-media {
      min-height: 240px;
    }
  }
</style>
